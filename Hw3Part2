import numpy as np
import matplotlib.pyplot as plt
import seaborn as sns


def simulate_diffusion(v, a, beta, tau, dt=1e-3, scale=1.0, max_time=10.0):
    """
    Simulate a single trial of the Drift Diffusion Model (DDM).

    Parameters
    ----------
    v : float
        Drift rate (speed/direction of evidence accumulation).
    a : float
        Boundary separation (decision threshold).
    beta : float
        Starting point bias as proportion of boundary (0–1).
    tau : float
        Non-decision time (encoding + motor delay).
    dt : float, optional
        Time step size.
    scale : float, optional
        Noise scaling factor.
    max_time : float, optional
        Maximum allowed simulation time (not enforced here).

    Returns
    -------
    tuple
        (response_time, decision), where decision is:
        1 = upper boundary, 0 = lower boundary
    """

    # Initialize starting point based on bias
    y = beta * a

    # Initialize time and noise scaling
    t = 0.0
    noise_scale = scale * np.sqrt(dt)

    while True:
        # Update evidence with drift + noise
        y += v * dt + noise_scale * np.random.randn()
        t += dt

        # Check if upper boundary is reached (correct decision)
        if y >= a:
            return tau + t, 1

        # Check if lower boundary is reached (incorrect decision)
        if y <= 0:
            return tau + t, 0


def simulate_diffusion_n(
    num_sims, v, a, beta, tau, dt=1e-3, scale=1.0, max_time=10.0
):
    """
    Run multiple DDM simulations.

    Parameters
    ----------
    num_sims : int
        Number of trials to simulate.
    Remaining parameters are identical to `simulate_diffusion`.

    Returns
    -------
    np.ndarray
        Array of shape (num_sims, 2):
        column 0 = response times
        column 1 = decisions (1 = upper, 0 = lower)
    """

    results = np.zeros((num_sims, 2))

    for i in range(num_sims):
        rt, decision = simulate_diffusion(v, a, beta, tau, dt, scale, max_time)
        results[i, 0] = rt
        results[i, 1] = decision

    return results


def visualize_diffusion_model(data, figsize=(8, 6)):
    """
    Plot response time distributions for correct vs incorrect decisions.

    Parameters
    ----------
    data : np.ndarray
        Output from simulate_diffusion_n.
    figsize : tuple
        Size of the plot.

    Returns
    -------
    matplotlib.figure.Figure
    """

    fig, ax = plt.subplots(figsize=figsize)

    # Separate correct (upper) and incorrect (lower) RTs
    correct_rt = data[data[:, 1] == 1, 0]
    incorrect_rt = data[data[:, 1] == 0, 0]

    # Plot histograms
    sns.histplot(correct_rt, color="maroon", label="Correct responses", ax=ax)
    sns.histplot(incorrect_rt, color="gray", label="Incorrect responses", ax=ax)

    # Clean up plot aesthetics
    sns.despine()
    ax.set_xlabel("Response time (s)", fontsize=20)
    ax.set_ylabel("")
    ax.set_yticks([])
    ax.legend(fontsize=20)

    return fig


# -----------------------------
# Drift rate analysis
# -----------------------------

# Generate a range of drift rates
drift_rates = np.linspace(0.5, 1.5, 25)

mean_upper_rts = []
mean_lower_rts = []

# Simulate across drift rates
for v in drift_rates:
    data = simulate_diffusion_n(2000, v, a=3, beta=0.5, tau=0.7)

    # Extract RTs by decision boundary
    upper_rts = data[data[:, 1] == 1, 0]
    lower_rts = data[data[:, 1] == 0, 0]

    # Compute mean RTs
    mean_upper_rts.append(np.mean(upper_rts))
    mean_lower_rts.append(np.mean(lower_rts))

# Convert to arrays for plotting
mean_upper_rts = np.array(mean_upper_rts)
mean_lower_rts = np.array(mean_lower_rts)

# Plot mean RTs vs drift rate
plt.figure(figsize=(10, 6))
plt.plot(
    drift_rates,
    mean_upper_rts,
    color="purple",
    marker="o",
    label="Mean RT (Upper Boundary)",
)
plt.plot(
    drift_rates,
    mean_lower_rts,
    color="yellow",
    marker="o",
    label="Mean RT (Lower Boundary)",
)

plt.xlabel("Drift Rate (v)")
plt.ylabel("Mean Response Time (s)")
plt.title("Mean Response Time vs Drift Rate")
plt.legend()
plt.show()

# Compute difference between boundaries
mean_rt_difference = mean_upper_rts - mean_lower_rts

# Plot RT difference
plt.figure(figsize=(10, 6))
plt.plot(drift_rates, mean_rt_difference, color="green", label="Upper − Lower")

plt.xlabel("Drift Rate (v)")
plt.ylabel("Mean Response Time Difference")
plt.title("Difference in Mean RTs Between Boundaries")
plt.legend()
plt.show()


def analyze_parameter_impact_on_rts(param_values, param_name, fixed_params):
    """
    Analyze how varying one parameter affects RT statistics.

    Parameters
    ----------
    param_values : array-like
        Values of the parameter to test.
    param_name : str
        Name of parameter to vary ('v', 'a', 'beta', or 'tau').
    fixed_params : dict
        Dictionary of baseline parameters.

    Returns
    -------
    np.ndarray
        Array with columns:
        [mean_upper, std_upper, mean_lower, std_lower]
    """

    n_values = len(param_values)
    results = np.zeros((n_values, 4))

    for i, value in enumerate(param_values):
        # Copy baseline parameters and update one parameter
        params = fixed_params.copy()
        params[param_name] = value

        # Run simulations
        data = simulate_diffusion_n(2000, **params)

        # Separate RTs by boundary
        upper_rts = data[data[:, 1] == 1, 0]
        lower_rts = data[data[:, 1] == 0, 0]

        # Compute statistics safely (handle empty cases)
        results[i, 0] = np.mean(upper_rts) if len(upper_rts) > 0 else np.nan
        results[i, 1] = np.std(upper_rts) if len(upper_rts) > 0 else np.nan
        results[i, 2] = np.mean(lower_rts) if len(lower_rts) > 0 else np.nan
        results[i, 3] = np.std(lower_rts) if len(lower_rts) > 0 else np.nan

    return results


def plot_stats_separate(param_range, stats, param_name):
    """
    Plot mean RTs, standard deviations, and mean differences
    for a given parameter.

    Parameters
    ----------
    param_range : array-like
        Values of the parameter.
    stats : np.ndarray
        Output from analyze_parameter_impact_on_rts.
    param_name : str
        Name of the parameter being varied.
    """

    mean_upper = stats[:, 0]
    std_upper = stats[:, 1]
    mean_lower = stats[:, 2]
    std_lower = stats[:, 3]

    # Difference between upper and lower mean RTs
    mean_diff = mean_upper - mean_lower

    # --- Mean RTs ---
    plt.figure(figsize=(8, 6))
    plt.plot(param_range, mean_upper, marker="o", label="Upper Mean RT")
    plt.plot(param_range, mean_lower, marker="o", label="Lower Mean RT")
    plt.title(f"Mean RT vs {param_name}")
    plt.xlabel(param_name)
    plt.ylabel("Mean RT")
    plt.legend()
    plt.show()

    # --- Standard deviations ---
    plt.figure(figsize=(8, 6))
    plt.plot(
        param_range,
        std_upper,
        marker="o",
        linestyle="--",
        label="Upper Std RT",
    )
    plt.plot(
        param_range,
        std_lower,
        marker="o",
        linestyle="--",
        label="Lower Std RT",
    )
    plt.title(f"Std RT vs {param_name}")
    plt.xlabel(param_name)
    plt.ylabel("Std RT")
    plt.legend()
    plt.show()

    # --- Mean RT difference ---
    plt.figure(figsize=(8, 6))
    plt.plot(param_range, mean_diff, label="Upper − Lower")
    plt.title(f"Mean RT Difference vs {param_name}")
    plt.xlabel(param_name)
    plt.ylabel("Mean RT Difference")
    plt.legend()
    plt.show()


# -----------------------------
# Parameter sensitivity analysis
# -----------------------------

# Baseline parameters
fixed_params = {
    "v": 1,
    "a": 3,
    "beta": 0.5,
    "tau": 0.7,
}

# Parameter ranges
a_range = np.linspace(2, 5, 15)
beta_range = np.linspace(0.3, 0.7, 15)
tau_range = np.linspace(0.5, 1.0, 15)

# Run analyses
a_stats = analyze_parameter_impact_on_rts(a_range, "a", fixed_params)
beta_stats = analyze_parameter_impact_on_rts(beta_range, "beta", fixed_params)
tau_stats = analyze_parameter_impact_on_rts(tau_range, "tau", fixed_params)

# Plot results
plot_stats_separate(a_range, a_stats, "a")
plot_stats_separate(beta_range, beta_stats, "beta")
plot_stats_separate(tau_range, tau_stats, "tau")

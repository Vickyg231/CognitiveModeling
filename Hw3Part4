
import numpy as np
from scipy.stats import norm
import matplotlib.pyplot as plt


# Parameters
mu0 = 15 # Prior mean
sigma0 = 4 # Prior STD
truemu = 8 # True mean
sigma = 5 # Observation STD
n = 20 # Sample size

# Finding data
snoozeTimes = np.random.normal(loc = truemu, scale = sigma, size = n)
average = np.average(snoozeTimes)
variancePosterior = 1 / ((1 / sigma0**2) + (n / sigma**2))
meanPosterior = variancePosterior * ((mu0 / sigma0**2) + (n * average / sigma**2))
STDposterior = np.sqrt(variancePosterior)
linspace = np.linspace(0, 20, 500)
prior, posterior= norm.pdf(linspace, mu0, sigma0), norm.pdf(linspace, meanPosterior, STDposterior)

prior_samples = np.random.normal(mu0, sigma0, 10000)
posterior_samples = np.random.normal(meanPosterior, STDposterior, 10000)
plt.figure(figsize=(8,5))

plt.hist(prior_samples, bins=50, alpha=0.5, label="Prior belief")
plt.hist(posterior_samples, bins=50, alpha=0.5, label="Posterior belief")

plt.axvline(mu0, linestyle='dashed', label="Prior Mean")
plt.axvline(meanPosterior, linestyle='dashed', label="Posterior Mean")

plt.xlabel("Average Snooze Time (minutes)")
plt.ylabel("Frequency")
plt.title("Estimating Average Alarm Snooze Time")
plt.legend()

plt.show()
